# India Bot — Environment Variables
# Copy this file to .env and fill in your values.

# ------------------------------------------------------------------
# Interactive Brokers (IBKR) connection
# No API key needed — the bot connects to your locally running
# TWS (Trader Workstation) or IB Gateway via socket.
#
# Download TWS: https://www.interactivebrokers.com.au/en/trading/tws.php
# Download IB Gateway: https://www.interactivebrokers.com.au/en/trading/ibgateway.php
#
# Enable API in TWS: Edit > Global Configuration > API > Settings
#   - Check "Enable ActiveX and Socket Clients"
#   - Set port to 7497 (paper) or 7496 (live)
#   - Add 127.0.0.1 to trusted IPs
# ------------------------------------------------------------------
IBKR_HOST=127.0.0.1
IBKR_PORT=7497          # 7497=TWS paper, 7496=TWS live, 4002=Gateway live
IBKR_CLIENT_ID=1
IBKR_ACCOUNT=           # Leave blank to use your default IBKR account
IBKR_CURRENCY=INR

# ------------------------------------------------------------------
# Trading mode
# PAPER_TRADING=true  -> uses IBKR paper account (port 7497), no real money
# PAPER_TRADING=false -> uses IBKR live account (port 7496)
# ------------------------------------------------------------------
PAPER_TRADING=true

# Exchange: NSE for Indian stocks
DEFAULT_EXCHANGE=NSE

# ------------------------------------------------------------------
# Watchlist (comma-separated NSE symbols)
# ------------------------------------------------------------------
WATCHLIST=RELIANCE,TCS,HDFCBANK,INFY,ICICIBANK,KOTAKBANK,HINDUNILVR,AXISBANK,WIPRO,TATAMOTORS

# ------------------------------------------------------------------
# Market hours (IST)
# ------------------------------------------------------------------
MARKET_OPEN_TIME=09:15
MARKET_CLOSE_TIME=15:30
MARKET_TIMEZONE=Asia/Kolkata

# ------------------------------------------------------------------
# Risk / trading parameters
# ------------------------------------------------------------------
INITIAL_CAPITAL=100000
RISK_PER_TRADE=0.05
MAX_POSITIONS=10
STOP_LOSS_PCT=0.05
TAKE_PROFIT_PCT=0.12
TRADE_COOLDOWN_MINUTES=30
BUY_THRESHOLD_PCT=0.001
SELL_THRESHOLD_PCT=0.001

# ------------------------------------------------------------------
# Market regime (NIFTY 50 index)
# ------------------------------------------------------------------
MARKET_REGIME_SYMBOL=^NSEI
MARKET_REGIME_SHORT_WINDOW=50
MARKET_REGIME_LONG_WINDOW=200

# Loop interval in seconds (default: 1 hour)
LOOP_INTERVAL_SECONDS=3600

# Cache TTL for stock data (seconds)
STOCK_DATA_CACHE_TTL_SECONDS=900

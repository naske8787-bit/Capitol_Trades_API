# ── Alpaca credentials ──────────────────────────────────────────────────────
# Use your existing Alpaca keys (same ones as the trading_bot)
ALPACA_API_KEY=YOUR_ALPACA_API_KEY_HERE
ALPACA_API_SECRET=YOUR_ALPACA_API_SECRET_HERE
ALPACA_PAPER=true          # set to false for live trading

# ── Forex pairs to watch ────────────────────────────────────────────────────
FOREX_WATCHLIST=EUR/USD,GBP/USD,AUD/USD,USD/JPY,USD/CAD

# ── Risk management ─────────────────────────────────────────────────────────
RISK_PER_TRADE=0.01        # 1% of account balance risked per trade
STOP_LOSS_PCT=0.005        # 0.5% stop loss
TAKE_PROFIT_PCT=0.01       # 1.0% take profit
MAX_POSITIONS=3            # max concurrent open positions
TRADE_COOLDOWN_SECS=300    # 5 min cooldown per pair between trades

# ── Loop timing ─────────────────────────────────────────────────────────────
LOOP_INTERVAL_SECS=60      # evaluate every 60 seconds

# ── ML model settings ───────────────────────────────────────────────────────
LOOKBACK_BARS=60           # bars fed into LSTM per prediction
RETRAIN_EVERY_N_BARS=500   # full retrain every N bars (online learning)
INITIAL_TRAIN_BARS=500     # minimum bars needed before first train

# ── Technical indicator windows ─────────────────────────────────────────────
EMA_SHORT=9
EMA_LONG=21
RSI_PERIOD=14
ATR_PERIOD=14

# ── Suppress TensorFlow info logs ───────────────────────────────────────────
TF_CPP_MIN_LOG_LEVEL=3

# Internet research search provider
SEARCH_PROVIDER=serpapi
SEARCH_ENGINE=google
SEARCH_API_KEY=your-serpapi-key
